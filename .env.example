# =====================================================
# Financial Resume Monorepo - Environment Variables
# =====================================================

# JWT Authentication
JWT_SECRET=your_secure_jwt_secret_here

# PostgreSQL - Main Database (financial_resume)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=financial_resume

# PostgreSQL - Users Database
USERS_DB_HOST=localhost
USERS_DB_PORT=5434
USERS_DB_USER=postgres
USERS_DB_PASSWORD=postgres
USERS_DB_NAME=users_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# OpenAI (for AI Service)
OPENAI_API_KEY=sk-your-api-key-here
USE_AI_MOCK=true

# Service URLs (for inter-service communication)
USERS_SERVICE_URL=http://localhost:8083
AI_SERVICE_URL=http://localhost:8082
GAMIFICATION_SERVICE_URL=http://localhost:8081

# Environment
ENVIRONMENT=development
