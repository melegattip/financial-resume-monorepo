# =====================================================
# Financial Resume - Monolith Environment Variables
# =====================================================

# App
PORT=8080
APP_ENV=development
LOG_LEVEL=debug

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000

# Database (use DATABASE_URL OR individual DB_* vars)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/financial_resume?sslmode=disable

# Individual DB vars (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=financial_resume
DB_SSLMODE=disable

# JWT
JWT_SECRET=change-me-in-production

# OpenAI (optional - if empty, runs in mock mode)
OPENAI_API_KEY=
