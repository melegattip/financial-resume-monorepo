# 🚀 Variables de Entorno para Producción - GCP Cloud Run
# Copia este archivo a env.production y configura los valores reales

# ================================
# CONFIGURACIÓN DE GCP
# ================================
GCP_PROJECT_ID=financial-resume-514917546267
GCP_REGION=southamerica-east1

# ================================
# CONFIGURACIÓN DE BASE DE DATOS
# ================================
DB_HOST=<IP_DE_CLOUD_SQL>
DB_PORT=5432
DB_USER=<USUARIO_DB>
DB_PASSWORD=<PASSWORD_SEGURO>
DB_NAME=financial_resume
DB_SSLMODE=require

# ================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ================================
PORT=8080
GIN_MODE=release
GO_ENVIRONMENT=production
TZ=America/Sao_Paulo

# ================================
# CONFIGURACIÓN JWT
# ================================
JWT_SECRET=<GENERAR_SECRET_SEGURO_256_BITS>
JWT_ISSUER=financial-resume-engine
JWT_DURATION_HOURS=24

# ================================
# URLS DE MICROSERVICIOS
# ================================
GAMIFICATION_SERVICE_URL=https://financial-gamification-service-514917546267.southamerica-east1.run.app
AI_SERVICE_URL=https://financial-ai-service-514917546267.southamerica-east1.run.app

# ================================
# CONFIGURACIÓN DE LOGGING
# ================================
LOG_LEVEL=info

# ================================
# INSTRUCCIONES DE USO
# ================================
# 1. Copia este archivo: cp env.production.example env.production
# 2. Configura los valores reales (reemplaza los <PLACEHOLDERS>)
# 3. Carga las variables: source env.production
# 4. Ejecuta el deployment: ./scripts/deploy-gcp.sh

# ================================
# GENERAR JWT_SECRET SEGURO
# ================================
# Usa uno de estos comandos para generar un secret seguro:
# openssl rand -hex 32
# python -c "import secrets; print(secrets.token_hex(32))"
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" 